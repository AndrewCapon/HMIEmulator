      "modes": ":bypass:taptempo:enumeration:trigger:toggled:colouredlist:momentarytoggle:",
      "steps": [],
      "max_assigns": 1,
      "widgets": ["led","label"],
      "id": 4
    },{
      "uri"  : "/hmi/group1",
      "name" : "Footswitch B&C",
      "group": "Footswitch Groups",
      "gname": "B&C",
      "modes": ":enumeration:colouredlist:",
      "steps": [],
      "max_assigns": 1,
      "actuator_group": ["/hmi/footswitch1", "/hmi/footswitch2"],
      "id": 5
    }
  ]
